document.getElementById('cardGrid').addEventListener('click',function(e){
var card=e.target.closest('.card');
if(!card)return;
var id=card.getAttribute('data-card');
if(card.classList.contains('open')){
card.classList.remove('open');
return;
}
var allCards=document.querySelectorAll('.card.open');
for(var i=0;i<allCards.length;i++){allCards[i].classList.remove('open');}
if(!card.dataset.built){
var det=card.querySelector('.card-detail');
det.innerHTML=buildDetail(id);
card.dataset.built='1';
}
card.classList.add('open');
setTimeout(function(){card.scrollIntoView({behavior:'smooth',block:'start'});},100);
});
</script>

